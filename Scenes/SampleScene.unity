  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MedicineInteract
  shelfName: Respiratory_And_Baby_CareFF
  medicineNames:
  - PediaSure
  - 'Babyhaler '
  - Otrivin Baby Drops
  - Bisolvon Syrup
  - Sudocrem Baby
  - Pampers Baby Wipes
  - Calpol Infant Syrup
  - Mustela Baby Cream
  - Salinose Baby Spray
  - Bepanthen Baby Ointment
  descriptions:
  - Nutritional supplement for children
  - Helps babies use inhalers easily
  - Relieves blocked nose in babies
  - Helps clear mucus and cough
  - Protects baby skin from irritation
  - Gentle cleansing wipes for babies
  - Fever and pain relief for infants
  - Moisturizes and protects baby skin
  - Saline spray for baby nasal cleaning
  - Treats diaper rash and skin irritation
  dosages:
  - Two servings daily
  - Use with inhaler when needed
  - 2 drops in each nostril
  - 5 ml twice daily
  - Apply after diaper change
  - Use when needed
  - Use every 6 hours if needed
  - Apply twice daily
  - One spray per nostril
  - Apply thin layer after cleaning
  warnings:
  - Use under parental supervision
  - Clean device regularly
  - Do not overuse nasal drops
  - Keep away from children
  - For external use only
  - Avoid contact with eyes
  - Do not exceed recommended dose
  - Stop use if irritation occurs
  - Use sterile applicator
  - Store in cool dry place
  medicineButtonPrefab: {fileID: 4215889524743441131, guid: 5f48708349954534687400683b966091, type: 3}
