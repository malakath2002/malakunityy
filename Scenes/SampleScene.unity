  m_Script: {fileID: 11500000, guid: a201b9e1c92472344897c10002fd9a24, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MedicineInteract
  shelfName: Digestive_And_Stomach_Care
  medicineNames:
  - Duphalac
  - Colpermin
  - Riabal
  - 'Antodine '
  - Lacteol Fort
  - Gast-Reg
  - Spasmo Digestin
  - Pepzol
  - Normacol
  - Colona
  descriptions:
  - Used for constipation relief
  - Helps reduce bloating and IBS symptoms
  - Relieves stomach and intestinal spasms
  - Reduces stomach acid and heartburn
  - Restores healthy intestinal bacteria
  - Relieves gas and stomach discomfort
  - Improves digestion and relieves cramps
  - Treats acid reflux and ulcers
  - Supports bowel movement regularity
  - Used for irritable bowel syndrome
  dosages:
  - 15 ml once daily
  - One capsule before meals
  - One tablet three times daily
  - One tablet before sleep
  - One sachet daily
  - One tablet after food
  - One tablet before meals
  - 'One capsule every morning '
  - Use with plenty of water
  - One tablet twice daily
  warnings:
  - Drink enough water during use
  - Avoid excessive use
  - Consult doctor if symptoms continue
  - Do not exceed recommended dose
  - Keep away from children
  - Store in cool dry place
  - Not suitable for severe abdominal pain
  - May cause mild bloating
  - Use under medical advice if pregnant
  - Stop use if allergic reaction occurs
  medicineButtonPrefab: {fileID: 0}
  buttonContainer: {fileID: 703256715}
